# ============================================================
# UITP — Universal Image Transfer Portal
# Copy this file to .env and fill in your values.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=uitp
DB_USER=uitp
DB_PASSWORD=uitp_secret_change_me

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_characters_long

# Token expiry (e.g. 24h, 7d)
JWT_EXPIRES_IN=24h

# ── AES credential encryption ────────────────────────────────
# 32-byte hex key. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change_me_32_byte_hex_key_here_00000000000000000000000000000000

# ── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Comma-separated allowed origins (no trailing slash)
CORS_ORIGIN=http://localhost:3000,http://uitp-frontend

# ── Frontend (Vite build-time) ───────────────────────────────
VITE_API_URL=http://localhost:4000
