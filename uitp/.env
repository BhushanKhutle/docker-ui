# ============================================================
# UITP — Universal Image Transfer Portal
# Copy this file to .env and fill in your values.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=uitp
DB_USER=uitp
DB_PASSWORD=Admin123

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=6d19a8f271c7784f5bda4499370e387c045ff7af024f9e7683a2810f317febd0a82fbade87a3ed8654c5b8304e0cc7e5d17e062ae8e2bd8bcd92fe18fb137505

# Token expiry (e.g. 24h, 7d)
JWT_EXPIRES_IN=24h

# ── AES credential encryption ────────────────────────────────
# 32-byte hex key. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=331d36989ef22f10fdf95d55ef920b0c105438ed648f14e85cee51c3159e188c

# ── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Comma-separated allowed origins (no trailing slash)
CORS_ORIGIN=*

# ── Frontend (Vite build-time) ───────────────────────────────
VITE_API_URL=http://65.2.75.137:4000
